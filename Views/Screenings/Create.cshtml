@model ScreeningCreateViewModel
@{
    ViewData["Title"] = "Create Screening";
}

<h1 class="mb-4">Create Screening</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="FilmTitle" class="form-label"></label>
                <input asp-for="FilmTitle" class="form-control" />
                <span asp-validation-for="FilmTitle" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="StartTime" class="form-label"></label>
                <input asp-for="StartTime" class="form-control" type="datetime-local" />
                <span asp-validation-for="StartTime" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CinemaId" class="form-label"></label>
                <select asp-for="CinemaId" asp-items="ViewBag.CinemaId" class="form-select">
                    <option value="">Select cinema</option>
                </select>
                <span asp-validation-for="CinemaId" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Create screening</button>
            <a asp-action="Index" class="btn btn-secondary">Back to screenings</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
