@{
    ViewData["Title"] = "Home";
}

<div class="p-4 p-md-5 mb-4 bg-light rounded-3">
    <div class="container-fluid py-2">
        <h1 class="display-6 fw-semibold">Cinema Ticket System</h1>
        <p class="col-md-9 mb-4">
            Browse screenings, manage your profile, and reserve or release seats for available sessions.
        </p>
        <a class="btn btn-primary me-2" asp-controller="Screenings" asp-action="Index">View screenings</a>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a class="btn btn-outline-secondary" asp-controller="Profile" asp-action="Edit">Edit profile</a>
        }
    </div>
</div>
